[sqlfluff]
dialect = snowflake
templater = jinja

[sqlfluff:templater:jinja]
project_dir = ./elite_dbt_project
profiles_dir = ./elite_dbt_project
undefined_variables = ignore

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = lower

[sqlfluff:rules:layout.long_lines]
max_line_length = 120

# Enforce spaces around operators
operator.newlines_before_binary_operator = false

# Enforce lowercase for column names
capitalisation.column_names = lower

[sqlfluff:layout:type:comma]
line_position = leading

[sqlfluff:rules:layout.indent]
disabled = true